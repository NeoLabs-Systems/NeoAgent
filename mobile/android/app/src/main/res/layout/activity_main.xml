<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- ── Fixed header ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:background="#12111F"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <!-- Logo icon (layers mark — matches web app) -->
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="9dp"
            android:src="@drawable/ic_notification"
            android:tint="#7C4DFF"
            android:contentDescription="NeoAgent logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NeoAgent"
            android:textColor="#EEEEEE"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.01" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_marginEnd="7dp" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting…"
            android:textColor="#666688"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ── Content area (WebView | Settings panel) ──────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Browser tab: embedded WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />

        <!-- Settings tab: connection + settings + log -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="28dp">

            <!-- ── Connection card ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTION"
                    android:textColor="#44435F"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/connStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connecting…"
                            android:textColor="#EEEEEE"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/connUrlText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#44435F"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReconnect"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Reconnect"
                        android:background="@drawable/bg_button_outline"
                        android:textColor="#7C4DFF"
                        android:textSize="12sp"
                        android:paddingHorizontal="16dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Settings card ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETTINGS"
                    android:textColor="#44435F"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Backend URL"
                    android:textColor="#888899"
                    android:textSize="12sp"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/inputUrl"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="#EEEEEE"
                    android:textColorHint="#333350"
                    android:hint="http://192.168.1.x:3333"
                    android:inputType="textUri"
                    android:paddingHorizontal="12dp"
                    android:textSize="13sp"
                    android:textCursorDrawable="@null"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="#888899"
                    android:textSize="12sp"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/inputUsername"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="#EEEEEE"
                    android:textColorHint="#333350"
                    android:hint="username"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textSize="13sp"
                    android:textCursorDrawable="@null"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#888899"
                    android:textSize="12sp"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="#EEEEEE"
                    android:textColorHint="#333350"
                    android:hint="password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="12dp"
                    android:textSize="13sp"
                    android:textCursorDrawable="@null"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Save &amp; Reconnect"
                    android:background="@drawable/bg_button_primary"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ── Activity log card ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ACTIVITY LOG"
                        android:textColor="#44435F"
                        android:textSize="10sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/btnClearLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textColor="#44435F"
                        android:textSize="12sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/logScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:fadeScrollbars="false">

                    <TextView
                        android:id="@+id/logText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="#AAAACC"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.5"
                        android:padding="2dp" />
                </ScrollView>
            </LinearLayout>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <!-- ── Bottom navigation ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#12111F"
        android:elevation="8dp">

        <TextView
            android:id="@+id/tabBrowser"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🌐  Browser"
            android:gravity="center"
            android:textColor="#7C4DFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="#2D2B55" />

        <TextView
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⚙  Settings"
            android:gravity="center"
            android:textColor="#555577"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
