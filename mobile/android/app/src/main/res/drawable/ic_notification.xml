<?xml version="1.0" encoding="utf-8"?>
<!--
  NeoAgent notification icon — layers mark matching the web app logo.
  White on transparent; system applies tint in the status bar / chip.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top layer -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.5"
        android:pathData="M12,2 L2,7 L12,12 L22,7 Z" />

    <!-- Middle line -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M2,12 L12,17 L22,12" />

    <!-- Bottom line -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M2,17 L12,22 L22,17" />
</vector>
